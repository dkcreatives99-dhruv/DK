  "instructions_to_main_agent": [
    "Install 'framer-motion' and 'lucide-react' immediately.",
    "Configure 'tailwind.config.js' to include the custom colors and fonts (Syne, Manrope).",
    "Create a 'Layout' component that handles the Navbar and Footer globally.",
    "Implement the 'Hero' section first with the abstract background and glassmorphism navbar.",
    "Use the 'Bento Grid' pattern for the Services section.",
    "Ensure all interactive elements have 'data-testid' attributes.",
    "Do not use default Shadcn styles; override them with the specified border radius and colors.",
    "For the 'Contact' form, use Shadcn form components but style them with the 'inputs.default' class defined above.",
    "Ensure the site is fully responsive, stacking grids to single columns on mobile."
  ],
  "UNIVERSAL_GUIDELINES_FOR_MAIN_AGENT": [
    "Dark colors look good when used independently without gradients. DO NOT use dark colors as gradients.",
    "Don't make generic centered layouts, simplistic gradients, and uniform styling.",
    "Create depth through layered design elements with z-index hierarchy.",
    "Use glass-morphism effects with backdrop filters (12-24px blur).",
    "You MUST NOT apply universal transition. Eg: 'transition: all'. This results in breaking transforms.",
    "You MUST NOT center align the app container.",
    "Always use modern button styles like pill-shaped, or sharp button with interaction animations.",
    "NEVER use AI assistant Emoji characters for icons.",
    "Every interaction needs micro-animations - hover states, transitions, parallax effects.",
    "Use 2-3x more spacing than feels comfortable.",
    "Subtle grain textures, noise overlays, custom cursors, selection states, and loading animations: separates good from extraordinary.",
    "Use 'sonner' for toasts."
  ]
}