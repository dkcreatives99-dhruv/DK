{
  "brand_identity": {
    "name": "DK Kinetic Digital LLP",
    "tagline": "Accelerating Digital Future",
    "tone": "Premium, Corporate, Futuristic, Trustworthy",
    "archetype": "Electric & Neon (Future) + Swiss (Authority)",
    "target_audience": "Startups, Corporates, E-commerce, Event Organizers"
  },
  "design_system": {
    "typography": {
      "headings": {
        "font_family": "Syne, sans-serif",
        "weights": ["700", "800"],
        "letter_spacing": "-0.02em",
        "usage": "Hero titles, Section headers"
      },
      "body": {
        "font_family": "Manrope, sans-serif",
        "weights": ["400", "500", "600"],
        "usage": "Paragraphs, UI elements, Buttons"
      },
      "mono": {
        "font_family": "JetBrains Mono, monospace",
        "usage": "Technical specs, decorative labels"
      }
    },
    "colors": {
      "primary": {
        "DEFAULT": "#2563EB",
        "foreground": "#FFFFFF",
        "hover": "#1D4ED8"
      },
      "secondary": {
        "DEFAULT": "#06B6D4",
        "foreground": "#FFFFFF"
      },
      "accent": {
        "DEFAULT": "#7C3AED",
        "foreground": "#FFFFFF"
      },
      "background": {
        "dark": "#020617",
        "light": "#F8FAFC",
        "card_dark": "rgba(2, 6, 23, 0.7)",
        "card_light": "#FFFFFF"
      },
      "text": {
        "primary_dark": "#F8FAFC",
        "secondary_dark": "#94A3B8",
        "primary_light": "#0F172A",
        "secondary_light": "#64748B"
      },
      "gradients": {
        "hero": "linear-gradient(135deg, #2563EB 0%, #06B6D4 100%)",
        "glass": "linear-gradient(180deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 100%)",
        "beam": "linear-gradient(90deg, transparent, #2563EB, transparent)"
      }
    },
    "spacing": {
      "container_padding": "px-6 md:px-12 lg:px-24",
      "section_gap": "py-20 md:py-32",
      "element_gap": "gap-6 md:gap-8"
    },
    "borders": {
      "radius": {
        "button": "9999px",
        "card": "16px",
        "input": "12px"
      },
      "width": "1px",
      "color_dark": "rgba(255, 255, 255, 0.1)",
      "color_light": "rgba(0, 0, 0, 0.1)"
    },
    "shadows": {
      "glow": "0 0 20px rgba(37, 99, 235, 0.3)",
      "card": "0 4px 24px -1px rgba(0, 0, 0, 0.1)",
      "glass": "0 8px 32px 0 rgba(31, 38, 135, 0.37)"
    }
  },
  "layout_strategies": {
    "theme_mode": "Hybrid",
    "sections": {
      "hero": {
        "theme": "dark",
        "layout": "Centered with asymmetric background elements",
        "features": ["3D Abstract Background", "Glassmorphism Navbar", "Glowing CTA"]
      },
      "services": {
        "theme": "light",
        "layout": "Bento Grid (Tetris Mode)",
        "features": ["Hover reveal cards", "Iconography", "Clean typography"]
      },
      "about": {
        "theme": "light",
        "layout": "Split Screen (Image Left, Text Right)",
        "features": ["Team photo", "Mission statement", "Stats counter"]
      },
      "tech_showcase": {
        "theme": "dark",
        "layout": "Full width immersive",
        "features": ["Brain circuit visual", "Animated data points", "Neon accents"]
      },
      "industries": {
        "theme": "light",
        "layout": "Carousel / Slider",
        "features": ["Industry icons", "Case study snippets"]
      },
      "contact": {
        "theme": "dark",
        "layout": "Two column (Form + Map/Info)",
        "features": ["Glassmorphism form", "Map integration", "Office image"]
      }
    }
  },
  "components": {
    "buttons": {
      "primary": "bg-primary text-white rounded-full px-8 py-4 font-semibold hover:shadow-glow transition-all duration-300",
      "secondary": "bg-transparent border border-white/20 text-white rounded-full px-8 py-4 hover:bg-white/10 transition-all duration-300",
      "outline_dark": "border border-primary text-primary hover:bg-primary hover:text-white rounded-full px-6 py-3 transition-all"
    },
    "cards": {
      "service_card": "bg-white p-8 rounded-2xl border border-slate-100 hover:shadow-xl transition-all duration-300 group relative overflow-hidden",
      "tech_card": "bg-slate-900/50 backdrop-blur-md border border-white/10 p-6 rounded-xl hover:border-primary/50 transition-all"
    },
    "inputs": {
      "default": "bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all"
    }
  },
